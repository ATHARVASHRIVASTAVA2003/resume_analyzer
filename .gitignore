# ============================================================================
# Keep These Files
# ============================================================================

# Keep directory structure
!.gitkeep
!**/.gitkeep

# Keep important documentation
!README.md
!USAGE_GUIDE.md
!LICENSE

# Keep configuration templates
!config.example.py
!.env.example

# Keep requirements
!requirements.txt
!setup.py

# Keep final models and metrics
!models/fraud_pipeline.joblib
!models/threshold.json
!reports/metrics/metrics.json
!reports/metrics/threshold_search.json

# Keep final visualizations
!reports/figures/confusion_matrix.png
!reports/figures/roc_curve.png
!reports/figures/pr_curve.png
!reports/figures/shap_summary.png
